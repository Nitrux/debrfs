#!/usr/bin/env bash

# SPDX-License-Identifier: BSD-3-Clause
# Copyright 2022-2025 <Nitrux Latinoamericana S.C. <hello@nxos.org>>


# -- Exit on errors.

set -eu


# -- Set program name and version.

TOOL_NAME="Debrfs"
CONFIG_SOURCE=""
COMMAND=""
DEBUG_DEBOOTSTRAP=0
DEBOOTSTRAP_CACHE_DIR=""


# -- Define the default configuration directory.

DEFAULT_CONFIG_DIR=/etc/debrfs.d


# -- Print messages to stderr.

puts_info() {
	if [ -n "$1" ]; then
		printf "%s: \e[34mInfo:\e[0m %s\n" "$TOOL_NAME" "$*" >&2
	fi
}


# -- Print success messages to stderr.

puts_success() {
	if [ -n "$1" ]; then
		printf "%s: \e[32mSuccess:\e[0m %s\n" "$TOOL_NAME" "$*" >&2
	fi
}


# -- Print error messages to stderr.

puts_error() {
	if [ -n "$1" ]; then
		printf "%s: \e[31mError:\e[0m %b\n" "$TOOL_NAME" "$*" >&2
	fi
}


# -- Print messages or text using multiple lines to stderr.

print_message() {
    if [ $# -eq 0 ]; then
        printf "\n" >&2
    else
        printf "%s\n" "$@" >&2
    fi
}


# -- Print warning messages to stderr.

puts_warning() {
    if [ -n "$1" ]; then
        printf "%s: \e[33mWarning:\e[0m %s\n" "$TOOL_NAME" "$*" >&2
    fi
}


# -- Parse command-line arguments.

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --conf)
                if [[ $# -lt 2 ]]; then
                    puts_error "Missing argument for --conf."
                    exit 1
                fi
                CONFIG_SOURCE="$2"
                shift 2
                ;;
            --conf=*)
                CONFIG_SOURCE="${1#*=}"
                shift
                ;;
            --dbg-db)
                DEBUG_DEBOOTSTRAP=1
                shift
                ;;
            create|help)
                if [[ -n "$COMMAND" ]]; then
                    puts_error "Multiple commands provided."
                    exit 1
                fi
                COMMAND="$1"
                shift
                ;;
            --)
                shift
                break
                ;;
            -*)
                puts_error "Unknown option '$1'."
                exit 1
                ;;
            *)
                if [[ -z "$COMMAND" ]]; then
                    COMMAND="$1"
                    shift
                else
                    puts_error "Unexpected argument '$1'."
                    exit 1
                fi
                ;;
        esac
    done

    if [[ $# -gt 0 ]]; then
        puts_error "Unexpected arguments after '--'."
        exit 1
    fi
}


# -- Load and validate a single configuration file.

load_config_file() {
    local config_file="$1"

    if [[ ! -r "$config_file" ]]; then
        puts_error "Configuration file not found or not readable: $config_file"
        exit 1
    fi

    puts_info "Loading configuration from $config_file..."

    if grep -nEv '^[[:space:]]*(#.*)?$|^[A-Z_][A-Z0-9_]*=.*$' "$config_file"; then
        puts_error "Invalid configuration file format in $config_file. Only variable assignments are allowed."
        exit 1
    fi

    if grep -E '[;&|$`]' "$config_file" | grep -vE '^[[:space:]]*#'; then
        puts_error "Configuration file $config_file contains potentially dangerous characters (;, &, |, \$, \`)."
        exit 1
    fi

    # shellcheck source=/dev/null
    . "$config_file"
}


# -- Load and validate configuration sources.

load_config() {
    local -a config_files=()
    local nullglob_was_set=0

    if shopt -q nullglob; then
        nullglob_was_set=1
    fi
    shopt -s nullglob

    if [[ -n "$CONFIG_SOURCE" ]]; then
        if [[ -d "$CONFIG_SOURCE" ]]; then
            config_files=("$CONFIG_SOURCE"/*.conf)
        else
            config_files=("$CONFIG_SOURCE")
        fi
    elif [[ -d "$DEFAULT_CONFIG_DIR" ]]; then
        config_files=("$DEFAULT_CONFIG_DIR"/*.conf)
    fi

    if [[ $nullglob_was_set -eq 0 ]]; then
        shopt -u nullglob
    fi

    if [[ ${#config_files[@]} -eq 0 ]]; then
        puts_error "No configuration files found."
        exit 1
    fi

    for config_file in "${config_files[@]}"; do
        load_config_file "$config_file"
    done

    local required_vars=("ROOTFS_VARIANT" "ROOTFS_ARCH" "ROOTFS_SUITE" "ROOTFS_DIR" "ROOTFS_MIRROR")
    for var in "${required_vars[@]}"; do
        if [[ -z "${!var:-}" ]]; then
            puts_error "Required variable $var is not set in configuration."
            exit 1
        fi
    done

    if [[ -n "${ROOTFS_DEBOOTSTRAP_DIR:-}" ]]; then
        if [[ ! -d "$ROOTFS_DEBOOTSTRAP_DIR" ]]; then
            puts_error "ROOTFS_DEBOOTSTRAP_DIR points to a missing directory: $ROOTFS_DEBOOTSTRAP_DIR"
            exit 1
        fi

        if [[ ! -r "$ROOTFS_DEBOOTSTRAP_DIR/functions" ]]; then
            puts_error "ROOTFS_DEBOOTSTRAP_DIR is missing the expected functions file: $ROOTFS_DEBOOTSTRAP_DIR/functions"
            exit 1
        fi

        if [[ ! -r "$ROOTFS_DEBOOTSTRAP_DIR/scripts/$ROOTFS_SUITE" ]]; then
            puts_error "ROOTFS_DEBOOTSTRAP_DIR is missing the suite script for $ROOTFS_SUITE: $ROOTFS_DEBOOTSTRAP_DIR/scripts/$ROOTFS_SUITE"
            exit 1
        fi
    fi

    if [[ -n "${ROOTFS_DEBOOTSTRAP_DIR:-}" ]]; then
        local debootstrap_version
        debootstrap_version="$(dpkg-query -W -f='${Version}' debootstrap 2>/dev/null || true)"

        if [[ -z "$debootstrap_version" ]]; then
            puts_error "Unable to determine the installed debootstrap package version."
            exit 1
        fi

        if [[ "$debootstrap_version" != *devuan* ]]; then
            puts_error "The installed debootstrap package is not the Devuan build: $debootstrap_version"
            puts_error "This configuration uses ROOTFS_DEBOOTSTRAP_DIR, so debootstrap must be the Devuan-flavored package."
            exit 1
        fi
    fi

    puts_success "Configuration loaded successfully."
}


# -- Cleanup function to remove temporary directories.

cleanup() {
    if [[ -n "${ROOTFS_DIR:-}" ]] && [[ -d "$ROOTFS_DIR" ]] && [[ "${KEEP_ROOTFS:-false}" != "true" ]]; then
        puts_info "Cleaning up temporary directory: $ROOTFS_DIR"
        rm -rf "$ROOTFS_DIR"
    fi

    if [[ -n "${DEBOOTSTRAP_CACHE_DIR:-}" ]] && [[ -d "$DEBOOTSTRAP_CACHE_DIR" ]]; then
        puts_info "Cleaning up temporary debootstrap cache: $DEBOOTSTRAP_CACHE_DIR"
        rm -rf "$DEBOOTSTRAP_CACHE_DIR"
    fi
}


# -- Function to create tar archive.

create_archive() {
    local tar_path="$1"
    
    puts_info "Creating compressed archive at $tar_path..."
    
    local compression_tool="${COMPRESSION_TOOL:-xz}"
    local compression_level="${COMPRESSION_LEVEL:-9}"
    local tar_opts=(
        -I "$compression_tool -$compression_level"
        -cf "$tar_path"
        --exclude="var/cache/apt/archives"
    )

    if [[ $DEBUG_DEBOOTSTRAP -eq 1 ]]; then
        tar_opts=(-I "$compression_tool -$compression_level" -cvf "$tar_path" --exclude="var/cache/apt/archives")
    fi
    
    if ! (cd "$ROOTFS_DIR" && tar "${tar_opts[@]}" .); then
        puts_error "Failed to create archive."
        return 1
    fi
    
    return 0
}


# -- Function to display help message.

show_help() {
    cat <<EOF

Description:
    Create small Debian rootfs TAR files.

Report bugs at: https://github.com/Nitrux/nuts/issues.

Usage: $(basename "$0") [--conf FILE|DIR] [--dbg-db] <command>

Commands:
  create    Create and compress the root filesystem (rootfs).
  help      Display this help message.

Examples:
  sudo $(basename "$0") create
  sudo $(basename "$0") create --conf /etc/debrfs.d/minbase-testing-no-systemd.conf
  sudo $(basename "$0") create --dbg-db
EOF
}


# -- Function to create the root filesystem.

create_rootfs() {
    puts_info "Starting root filesystem creation process..."

    local base_name="${TAR_NAME_BASE:-${TAR_FILE:-rootfs}}"
    TAR_FILE="${base_name}-$(date +%Y.%m.%d-%H.%M).tar.xz"

    if ! command -v debootstrap >/dev/null 2>&1; then
        puts_warning "debootstrap not found. Installing..."
        if ! apt -y install --no-install-recommends debootstrap; then
            puts_error "Failed to install debootstrap."
            exit 1
        fi
    else
        puts_info "debootstrap is already installed."
    fi

    if [[ ! -d $ROOTFS_DIR ]]; then
        puts_info "Creating rootfs directory: $ROOTFS_DIR"
        if ! mkdir -p "$ROOTFS_DIR"; then
            puts_error "Failed to create directory: $ROOTFS_DIR"
            exit 1
        fi
    else
        puts_warning "Directory exists. Cleaning: $ROOTFS_DIR"
        if ! rm -rf "$ROOTFS_DIR" || ! mkdir -p "$ROOTFS_DIR"; then
            puts_error "Failed to clean directory: $ROOTFS_DIR"
            exit 1
        fi
    fi

    puts_info "Running debootstrap (this may take a while)..."
    puts_info "Variant: $ROOTFS_VARIANT | Arch: $ROOTFS_ARCH | Suite: $ROOTFS_SUITE"

    DEBOOTSTRAP_CACHE_DIR="$(mktemp -d /var/tmp/debrfs-debootstrap-cache.XXXXXX)"

    local debootstrap_cmd=(
        debootstrap
        --variant="$ROOTFS_VARIANT"
        --arch="$ROOTFS_ARCH"
        --cache-dir="$DEBOOTSTRAP_CACHE_DIR"
    )

    if [[ -n "${ROOTFS_INCLUDE:-}" ]]; then
        debootstrap_cmd+=(--include="$ROOTFS_INCLUDE")
    fi

    if [[ -n "${ROOTFS_EXCLUDE:-}" ]]; then
        debootstrap_cmd+=(--exclude="$ROOTFS_EXCLUDE")
    fi

    debootstrap_cmd+=("$ROOTFS_SUITE" "$ROOTFS_DIR" "$ROOTFS_MIRROR")

    local debootstrap_log=""
    if [[ $DEBUG_DEBOOTSTRAP -eq 0 ]]; then
        debootstrap_log="$(mktemp /var/tmp/debrfs-debootstrap.XXXXXX.log)"
    fi

    local debootstrap_runner
    if [[ -n "${ROOTFS_DEBOOTSTRAP_DIR:-}" ]]; then
        puts_info "Using custom debootstrap directory: $ROOTFS_DEBOOTSTRAP_DIR"
        debootstrap_runner=(env DEBOOTSTRAP_DIR="$ROOTFS_DEBOOTSTRAP_DIR" "${debootstrap_cmd[@]}")
    else
        debootstrap_runner=("${debootstrap_cmd[@]}")
    fi

    if [[ $DEBUG_DEBOOTSTRAP -eq 1 ]]; then
        if ! "${debootstrap_runner[@]}"; then
            puts_error "debootstrap failed while creating the base system. The output above shows the failing step."
            exit 1
        fi
    else
        if ! "${debootstrap_runner[@]}" >"$debootstrap_log" 2>&1; then
            puts_error "debootstrap failed while creating the base system. The last output lines are below."
            tail -n 20 "$debootstrap_log" >&2
            rm -f "$debootstrap_log"
            exit 1
        fi
    fi

    if [[ -n "$debootstrap_log" ]]; then
        rm -f "$debootstrap_log"
    fi

    puts_success "debootstrap completed successfully."

    local final_dir="${OUTPUT_DIR:-$PWD}"

    if [[ ! -d "$final_dir" ]]; then
        puts_info "Creating output directory: $final_dir"
        mkdir -p "$final_dir"
    fi

    local temp_tar_path
    temp_tar_path="$(dirname "$ROOTFS_DIR")/$(basename "$TAR_FILE")"

    local final_tar_path
    final_tar_path="$final_dir/$(basename "$TAR_FILE")"

    if [[ -f "$final_tar_path" ]]; then
        puts_warning "Archive already exists at $final_tar_path. Removing..."
        rm -f "$final_tar_path"
    fi

    if ! create_archive "$temp_tar_path"; then
        puts_error "Failed to create archive."
        exit 1
    fi

    puts_info "Moving archive to $final_tar_path..."
    if ! mv "$temp_tar_path" "$final_tar_path"; then
         puts_error "Failed to move archive to destination."
         exit 1
    fi

    puts_success "Root filesystem archive created at $final_tar_path"

    if command -v du >/dev/null 2>&1;
    then
        local size
        size=$(du -h "$final_tar_path" | cut -f1)
        puts_info "Archive size: $size"
    fi
}

# -- Parse arguments before loading configuration.

parse_args "$@"


# -- Display help before any privileged actions or configuration loading.

if [[ "$COMMAND" == "help" ]]; then
    show_help
    exit 0
fi


# -- Check if running with root privileges or ask for sudo.

(( EUID != 0 )) && exec sudo -- "$0" "$@"


# -- Load configuration before setting up trap.

load_config


# -- Set up cleanup trap after configuration is loaded.

trap cleanup EXIT ERR


# -- Main script logic.

if [[ -z "$COMMAND" ]]; then
    puts_error "No command provided."
    show_help
    exit 1
fi

case "$COMMAND" in
    create)
        create_rootfs
        ;;
    help)
        show_help
        ;;
    *)
        puts_error "Unknown command '$COMMAND'."
        show_help
        exit 1
        ;;
esac
